# Copy to backend/.env and frontend/.env.local as needed

# Database (Render external URL for local dev)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Backend
NODE_ENV=development
PORT=4000
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=30
FRONTEND_URL=http://localhost:3000
DRAW_SECRET=change-me-draw-seed

# Stripe (test mode)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Email (optional — falls back to console logs if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Orbit <noreply@localhost>"

# Seed (optional overrides)
SEED_ADMIN_EMAIL=admin@orbit.local
SEED_ADMIN_PASSWORD=AdminAdmin123!

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
